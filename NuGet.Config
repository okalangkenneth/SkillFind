<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Clear VS fallback package folders that don't exist inside Docker containers -->
  <fallbackPackageFolders>
    <clear />
  </fallbackPackageFolders>
  <!-- Limit concurrent HTTP requests to nuget.org to avoid EAGAIN socket errors -->
  <config>
    <add key="maxHttpRequestsPerSource" value="8" />
  </config>
</configuration>
